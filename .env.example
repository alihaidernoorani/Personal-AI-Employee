# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Absolute path to your Obsidian vault
VAULT_PATH=/absolute/path/to/AI_Employee_Vault

# Safety flag — keeps all external actions as logs only.
# Set to 'false' only when you are ready for live execution.
DRY_RUN=true

# --- Orchestrator (Gold tier) ---
# Fallback folder used when vault is temporarily unavailable
VAULT_TEMP_PATH=/absolute/path/to/AI_Employee_Vault_Temp

# --- Gmail ---
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
GMAIL_CREDENTIALS=/absolute/path/to/credentials.json

# --- WhatsApp ---
WHATSAPP_SESSION_PATH=/absolute/path/to/playwright-profile

# --- Finance Watcher ---
# Path to bank export CSV (columns: id,date,payee,amount,reference,category)
BANK_CSV_PATH=

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# --- Facebook ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# --- Instagram ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# --- Twitter / X ---
TWITTER_BEARER_TOKEN=

# --- Odoo ---
# Local agent: set ODOO_URL to your Odoo instance (cloud or local)
# Cloud VM: ODOO_URL=http://localhost:8069 (connects to docker container)
ODOO_URL=https://<your-odoo-host>/jsonrpc
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=

# Cloud agent uses draft-only mode (set to true in /root/.env.cloud on cloud VM)
ODOO_DRAFT_ONLY=false

# --- Twitter / X (OAuth 1.0a for posting) ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- Platinum: Cloud/Local Split ---
# Identity of this agent instance (local or cloud)
AGENT_ROLE=local

# SSH connection details for cloud VM
CLOUD_VM_HOST=
CLOUD_VM_USER=root
CLOUD_VAULT_PATH=/root/AI_Employee_Vault

# Stale task recovery threshold in seconds (default: 600 = 10 minutes)
STALE_TASK_TIMEOUT_SECONDS=600

# Syncthing API key (found in Syncthing GUI → Actions → Settings → API Key)
SYNCTHING_API_KEY=
